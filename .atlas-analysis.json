  "keyFeatures": [
    "Visual drag-and-drop workflow editor powered by React Flow",
    "Multi-provider AI support: OpenAI, Anthropic (Claude), and Google Gemini",
    "Event-driven execution via Inngest with real-time progress streaming",
    "Trigger support for manual, HTTP, Google Forms, and Stripe webhooks",
    "Notification actions for Discord, Slack, Telegram, and Email (SMTP)",
    "Credential management for securely storing API keys and tokens",
    "Subscription billing via Polar.sh with a Pro tier",
    "Topological sort ensuring correct node execution order"
  ],
  "publicApiSurface": [
    "POST /api/inngest — Inngest event ingestion endpoint",
    "POST /api/trpc/workflows — Workflow CRUD operations",
    "POST /api/trpc/credentials — Credential management",
    "POST /api/trpc/aiModels — AI model configuration",
    "POST /api/webhooks/google-form — Google Form trigger webhook",
    "POST /api/webhooks/stripe — Stripe event trigger webhook",
    "POST /api/auth/* — Authentication endpoints (better-auth)",
    "NodeType enum: MANUAL_TRIGGER | HTTP_REQUEST | GOOGLE_FORM_TRIGGER | STRIPE_TRIGGER | OPENAI | ANTHROPIC | GEMINI | DISCORD | SLACK | TELEGRAM | EMAIL_SMTP",
    "executeWorkflow Inngest function — orchestrates node execution via topological sort"
  ]
